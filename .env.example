# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI - server-only. Actuele modelnamen kiezen bij bouwstart (backlog EPIC-14)
# en vastleggen in Docs/dependencies.md. Filter = goedkoop model, analysis = sterk model.
OPENAI_API_KEY=
OPENAI_FILTER_MODEL=
OPENAI_ANALYSIS_MODEL=

# Bronnen - server-only (endpoints en limieten: Docs/Specs/news-sources.md)
FINANCIAL_NEWS_API_KEY=                          # Finnhub: company/market news, quotes, earnings calendar
FINANCIAL_NEWS_BASE_URL=https://finnhub.io/api/v1
BROAD_NEWS_API_KEY=                              # Marketaux brede laag (GDELT heeft geen key nodig)
MOVERS_API_KEY=                                  # Alpha Vantage TOP_GAINERS_LOSERS (mover sweep)
EDGAR_USER_AGENT=EdgeTerminal robin@mdejong.dev  # verplichte User-Agent voor SEC EDGAR
MARKET_DATA_API_KEY=                             # delayed quotes US+EU (market context + advice tracking)
MARKET_DATA_BASE_URL=

# Automatisering (slice 3)
DISCOVERY_SCAN_CRON_SECRET=

# Let op: GEMINI_* en NEWS_DISCOVERY_* zijn vervallen per 2026-06-12.
# De code migreert van de oude OPENAI/GEMINI-placeholders naar bovenstaand schema in backlog EPIC-14.
